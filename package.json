{
  "name": "acme-ui-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @acme/sandbox dev",
    "demo": "pnpm --filter @acme/scheduling-demo dev",
    "build": "pnpm --filter @acme/ui build && pnpm --filter @acme/scheduling-demo build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @acme/ui test && pnpm --filter @acme/scheduling-demo test"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  }
}
